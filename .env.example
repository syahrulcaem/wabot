# Salin file ini menjadi .env lalu isi nilainya

# --- Gemini AI ---
GEMINI_API_KEY=your_gemini_api_key_here
# Model yang digunakan (opsional, default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# --- PostgreSQL ---
DB_HOST=your.database.server.com
DB_PORT=5432
DB_NAME=office_db
DB_USER=username
DB_PASSWORD=password
# Set ke true jika server memerlukan SSL (Supabase, Railway, Neon, Aiven, dsb.)
DB_SSL=true

# --- Admin Panel ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ganti_dengan_password_kuat

# --- Web Server ---
# PORT otomatis diset oleh platform hosting (Railway, Render, dsb.)
PORT=3000
